<Window x:Class="OnEntryDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OnEntry" Height="600" Width="900"
        Background="#1a1a1a" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="1" Background="#1a1a1a" BorderBrush="#333">
            <TabItem Header="Vault" Background="#1a1a1a" Foreground="White">
                <Grid Background="#1a1a1a">
                    <TextBlock Text="Vault content" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </TabItem>
            <TabItem Header="Search" Background="#1a1a1a" Foreground="White">
                <Grid Background="#1a1a1a">
                    <TextBlock Text="Search content" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </TabItem>
            <TabItem Header="Generator" Background="#1a1a1a" Foreground="White">
                <Grid Background="#1a1a1a">
                    <TextBlock Text="Generator content" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </TabItem>
            <TabItem Header="Settings" Background="#1a1a1a" Foreground="White">
                <Grid Background="#1a1a1a">
                    <TextBlock Text="Settings content" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>